<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <data>
        <variable
            name="vm"
            type="com.lttclaw.metronome.viewmodel.PlayViewModel" />
    </data>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:keepScreenOn="true"
        android:padding="16dp">

        <!-- 主控制按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:spacing="12dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_start"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:enabled="@{!vm.playing}"
                android:text="启动"
                android:backgroundTint="@color/success"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <Button
                android:id="@+id/btn_pause"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:enabled="@{vm.playing}"
                android:text="@{vm.pauseBtnText}"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textSize="16sp"
                tools:text="暂停"/>

            <Button
                android:id="@+id/btn_stop"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:enabled="@{vm.playing}"
                android:text="停止"
                android:backgroundTint="@color/danger"
                android:textColor="@color/white"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- 信息显示卡片 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{`当前第 ` + String.valueOf(vm.curSectionIndex + 1) + ` 小节`}"
                    android:textSize="16sp"
                    android:textColor="@android:color/darker_gray"
                    tools:text="当前第 1 小节"/>

                <TextView
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{String.valueOf(vm.curPlayingIndex)}"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"
                    tools:text="12"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- 当前背景音乐信息 -->
        <TextView
            android:id="@+id/tv_currentBgMusic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@{`背景音乐:  ` + vm.curMusicName}"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:paddingStart="8dp"
            tools:text="背景音乐: 暂无"/>

        <!-- 功能按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:spacing="8dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_batch_edit"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/batch_edit"
                android:backgroundTint="@color/warning"
                android:textColor="@color/white"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/btn_go_setting"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:enabled="@{!vm.playing}"
                android:text="编辑小节"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/btn_bg_setting"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="背景音乐"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:textSize="15sp"/>
        </LinearLayout>

        <!-- 小节列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_play"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:itemCount="5"
            tools:listitem="@layout/item_play_section"/>

    </LinearLayout>
</layout>